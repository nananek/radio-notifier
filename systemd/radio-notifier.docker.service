[Unit]
Description=Radio notifier (Docker)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
Environment=IMAGE=radio-notifier:latest
# In rootless docker / podman, container root maps to the host user, so we do NOT
# pass --user here. For rootful docker, add `--user $(id -u):$(id -g)`.
ExecStart=/usr/bin/docker run --rm \
  --network bridge \
  -e TZ=Asia/Tokyo \
  -v %h/.config/radio-notifier:/config/radio-notifier:ro \
  -v %h/.local/state/radio-notifier:/state/radio-notifier \
  ${IMAGE} run
